# Публичный URL сайта (без слэша) — для metadata / Open Graph. На Vercel подставляется само; локально можно не задавать.
# NEXT_PUBLIC_SITE_URL=https://example.com

# URL бекенду (без слэша в конце). У проді має збігатися з CORS на сервері.
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# Cloudflare Turnstile (site key з панелі Turnstile). Якщо порожньо — капча на клієнті не показується;
# тоді на бекенді теж не виставляйте TURNSTILE_SECRET_KEY.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Дублюйте CLOSED_BETA з бекенду (1/true/yes). Якщо запит до API не вдався — сайт лишається закритим для гостей.
# NEXT_PUBLIC_CLOSED_BETA=1

# Опційно: проксі /api/* на бекенд (збірка Next). Тоді можна виставити NEXT_PUBLIC_API_URL=http://localhost:3000
# і всі fetch йтимуть через той самий origin без CORS.
# BACKEND_PROXY_URL=http://127.0.0.1:4000
